* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  font-size: 15px;
}

body {
  font-family: 'Lucida Grande', Helvetica, sans-serif;
  color: #2a2a2a;
}

.container {
  margin-top: 100px;
  margin-left: 60px;
}

h1 {
  font-family: 'Lato', Helvetica, sans-serif;
  font-weight: 100;
  font-size: 8em;
  opacity: 0.8;
  margin-bottom: 15px;
}

p {
  line-height: 1.7em;
  opacity: 0.9;
}

.medium-screen {
  display: none;
}

.small-screen {
  display: none;
}

.small-screen-icons {
  display: inline-block;
}

.about {
  padding-left: 10px;
  margin-bottom: 30px;
}

.icon-container {
  padding-left: 8px;
  opacity: 0.7;
}

.icon {
  width: 32px;
  height: 32px;
  margin-right: 15px;
}

.top {
  margin-top: 15px;
}

.mid {
  margin-top: 15px;
}

.low {
  margin-top: 15px;
}

.resume {
  text-decoration: underline !important;
}

a:link,
a:visited,
a:active {
  color: #2a2a2a;
  text-decoration: none;
}

a:hover {
  opacity: 0.8;
}

/* large screens */
@media (max-width: 1200px) {

  .container {
    margin-left: 40px;
  }

  h1 {
    font-size: 7.2em;
  }

  p {
    font-size: 0.9em;
  }

}

/* medium screens */
@media (max-width: 1010px) {

  h1 {
    font-size: 6em;
  }

  .large-screen {
    display: none;
  }

  .medium-screen {
    display: inline-block;
  }

}

/* small screens */
@media (max-width: 900px) {


  h1 {
    font-size: 2.5em;
    font-weight: 300;
    // font-weight: bold;
    padding-left: 5px;
  }

  p {
    font-size: 0.77em;
  }

  .container {
    margin-top: 30px;
    margin-left: 1px;
  }

  .large-screen {
    display: none;
  }

  .medium-screen {
    display: none;
  }

  .small-screen {
    display: inline-block;
  }

  .small-screen-icons {
    display: block;
    margin-top: 35px;
    margin-bottom: 15px;
  }

  .icon {
    width: 45px;
    height: 45px;
  }
}




